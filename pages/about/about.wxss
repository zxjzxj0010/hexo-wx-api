/* pages/about/about.wxss */
.about-page {
	min-height: 100vh;
	box-sizing: border-box;
	padding: 36rpx 28rpx 52rpx;
	background: linear-gradient(160deg, #fef8ef 0%, #ffe4cc 46%, #ffd8dc 100%);
	position: relative;
	overflow: hidden;
}

.bg-orb {
	position: absolute;
	border-radius: 9999rpx;
	filter: blur(8rpx);
	opacity: 0.35;
	z-index: 0;
}

.orb-a {
	width: 340rpx;
	height: 340rpx;
	top: -110rpx;
	right: -120rpx;
	background: #ff9d7a;
}

.orb-b {
	width: 420rpx;
	height: 420rpx;
	left: -160rpx;
	bottom: -140rpx;
	background: #ffce88;
}

.hero-card,
.content-card {
	position: relative;
	z-index: 1;
	border-radius: 28rpx;
	background: rgba(255, 255, 255, 0.82);
	border: 1rpx solid rgba(255, 255, 255, 0.9);
	box-shadow: 0 18rpx 48rpx rgba(148, 74, 15, 0.16);
}

.hero-card {
	padding: 34rpx 30rpx 26rpx;
}

.brand-row {
	display: flex;
	align-items: center;
	margin-bottom: 20rpx;
}

.brand-badge {
	padding: 8rpx 18rpx;
	border-radius: 999rpx;
	font-size: 22rpx;
	letter-spacing: 2rpx;
	color: #ffffff;
	background: linear-gradient(120deg, #ff7d45, #ff5d6b);
}

.brand-dot {
	width: 10rpx;
	height: 10rpx;
	border-radius: 50%;
	background: #ff8251;
	margin: 0 14rpx;
}

.brand-tag {
	font-size: 22rpx;
	color: #8f4c2a;
}

.title {
	display: block;
	font-size: 62rpx;
	font-weight: 700;
	line-height: 1.14;
	color: #2f1a12;
	margin-bottom: 12rpx;
}

.subtitle {
	display: block;
	font-size: 28rpx;
	line-height: 1.6;
	color: #6b3f2a;
	margin-bottom: 24rpx;
}

.slogen-wrap {
	border-radius: 22rpx;
	background: rgba(255, 255, 255, 0.74);
	border: 1rpx solid rgba(255, 176, 143, 0.55);
	padding: 16rpx;
}

.slogen {
	width: 100%;
	display: block;
}

.content-card {
	margin-top: 24rpx;
	padding: 28rpx;
}

.section-title {
	display: block;
	font-size: 34rpx;
	font-weight: 700;
	color: #2e1b14;
	margin-bottom: 18rpx;
}

.desc-body {
	padding: 20rpx 22rpx;
	border-radius: 18rpx;
	background: rgba(255, 244, 233, 0.84);
}

.desc-text {
	display: block;
	font-size: 28rpx;
	line-height: 1.8;
	color: #4f2f23;
	text-align: justify;
}